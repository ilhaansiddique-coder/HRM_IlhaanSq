// ──────────────────────────────────────────────────────────────
// HRM SaaS — Prisma Schema
// Single source of truth for the entire data model.
// ──────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// AUTH & USERS
// ═══════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  passwordHash  String    @map("password_hash")
  fullName      String    @default("User") @map("full_name")
  phone         String?
  emailVerified Boolean   @default(false) @map("email_verified")
  isSuperAdmin  Boolean   @default(false) @map("is_super_admin")
  mustResetPassword Boolean @default(false) @map("must_reset_password")
  image         String?
  lastSignInAt  DateTime? @map("last_sign_in_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  memberships   TenantMember[]
  activityLogs  ActivityLog[]
  employee      Employee?      @relation("UserEmployee")

  @@map("users")
}

model VerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  token     String   @unique
  type      String   @default("password_reset") // password_reset | email_verify | invite
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([email, type])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════════════════════
// TENANTS & MEMBERSHIP
// ═══════════════════════════════════════════════════════════════

enum TenantRole {
  owner
  admin
  manager
  staff
  member
  employee
}

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  plan      String   @default("starter")
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members          TenantMember[]
  invites          TenantInvite[]
  activityLogs     ActivityLog[]
  businessSettings BusinessSettings?
  systemSettings   SystemSettings?
  customSettings   CustomSetting[]
  rolePermissions  TenantRolePermission[]
  billing          TenantBilling?

  // HR module
  employees       Employee[]
  departments     Department[]
  positions       Position[]
  leaveTypes      LeaveType[]
  leaveRequests   LeaveRequest[]
  attendanceRecords AttendanceRecord[]
  breakSessions   BreakSession[]
  breakPenalties  BreakPenalty[]

  // HR Phase 2
  salaryStructures   SalaryStructure[]
  payrollPeriods     PayrollPeriod[]
  payrollRuns        PayrollRun[]
  payrollCustomColumns PayrollCustomColumn[]
  payrollBaseColumnOverrides PayrollBaseColumnOverride[]
  payrollRecomputeBackups    PayrollRecomputeBackup[]
  employeeAdvances   EmployeeAdvance[]
  reviewCycles       ReviewCycle[]
  goals              Goal[]
  reviews            Review[]
  jobPostings        JobPosting[]
  candidates         Candidate[]
  applications       Application[]
  courses            Course[]
  enrollments        Enrollment[]
  documentCategories DocumentCategory[]
  employeeDocuments  EmployeeDocument[]

  // Admin: approvals + notification center
  approvalRequests   ApprovalRequest[]
  notifications      Notification[]

  @@map("tenants")
}

model TenantMember {
  id        String     @id @default(uuid()) @db.Uuid
  tenantId  String     @map("tenant_id") @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  role      TenantRole @default(staff)
  isDefault Boolean    @default(false) @map("is_default")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_members")
}

model TenantInvite {
  id        String     @id @default(uuid()) @db.Uuid
  tenantId  String     @map("tenant_id") @db.Uuid
  email     String
  role      TenantRole @default(staff)
  token     String     @unique @default(uuid())
  expiresAt DateTime   @map("expires_at")
  createdAt DateTime   @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("tenant_invites")
}

model TenantRolePermission {
  id            String     @id @default(uuid()) @db.Uuid
  tenantId      String     @map("tenant_id") @db.Uuid
  role          TenantRole
  permissionKey String     @map("permission_key")
  allowed       Boolean    @default(false)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, role, permissionKey])
  @@map("tenant_role_permissions")
}

model TenantBilling {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @unique @map("tenant_id") @db.Uuid
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")
  plan                 String    @default("starter")
  status               String    @default("active") // active | trialing | past_due | cancelled
  seatCount            Int       @default(1) @map("seat_count")
  trialEndsAt          DateTime? @map("trial_ends_at")
  currentPeriodEnd     DateTime? @map("current_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_billing")
}

// ═══════════════════════════════════════════════════════════════
// SETTINGS
// ═══════════════════════════════════════════════════════════════

model BusinessSettings {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @unique @map("tenant_id") @db.Uuid
  businessName          String   @default("Your Business Name") @map("business_name")
  logoUrl               String?  @map("logo_url")
  phone                 String?
  whatsapp              String?
  email                 String?
  primaryEmail          String?  @map("primary_email")
  secondaryEmail        String?  @map("secondary_email")
  facebook              String?
  address               String?
  addressLine1          String?  @map("address_line1")
  addressLine2          String?  @map("address_line2")
  businessHours         String?  @map("business_hours")
  brandColor            String   @default("#2c7be5") @map("brand_color")
  createdBy             String?  @map("created_by") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("business_settings")
}

model SystemSettings {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @unique @map("tenant_id") @db.Uuid
  currencySymbol String   @default("$") @map("currency_symbol")
  currencyCode   String   @default("USD") @map("currency_code")
  timezone       String   @default("UTC")
  dateFormat     String   @default("DD/MM/YYYY") @map("date_format")
  timeFormat     String   @default("HH:mm") @map("time_format")
  lateThreshold       String? @map("late_threshold") // HH:mm — check-in after this time is late
  breakTimeThreshold  Int     @default(60) @map("break_time_threshold") // max break minutes before penalty
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("system_settings")
}

model CustomSetting {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  settingType String   @map("setting_type") // custom_css | head_snippet | body_snippet
  content     String?
  isEnabled   Boolean  @default(false) @map("is_enabled")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("custom_settings")
}

// ═══════════════════════════════════════════════════════════════
// AUDIT & LOGS
// ═══════════════════════════════════════════════════════════════

model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType])
  @@map("activity_logs")
}

// ═══════════════════════════════════════════════════════════════
// DEMO REQUESTS (public tenant signup pipeline)
// ═══════════════════════════════════════════════════════════════

model DemoRequest {
  id              String    @id @default(uuid()) @db.Uuid
  fullName        String    @map("full_name")
  businessName    String    @map("business_name")
  email           String
  phone           String
  businessType    String    @map("business_type") // wholesale | retail | distribution | manufacturing | other
  requestedSlug   String?   @map("requested_slug")
  requestedPlan   String    @default("starter") @map("requested_plan") // starter | professional | enterprise
  message         String?
  status          String    @default("pending") // pending | approved | rejected
  reviewedBy      String?   @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime? @map("reviewed_at")
  rejectionReason String?   @map("rejection_reason")
  tenantId        String?   @map("tenant_id") @db.Uuid
  approvedUserId  String?   @map("approved_user_id") @db.Uuid
  tempPassword    String?   @map("temp_password") // stored briefly for re-send capability
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("demo_requests")
}

// ═══════════════════════════════════════════════════════════════
// HR MODULE
// Phase 1: Employees, Departments, Positions, Leave, Attendance
// ═══════════════════════════════════════════════════════════════

enum EmploymentStatus {
  active
  on_leave
  terminated
  suspended
}

enum EmploymentType {
  full_time
  part_time
  contract
  intern
  freelance
}

enum LeaveStatus {
  pending
  approved
  rejected
  cancelled
}

model Department {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  name            String
  code            String?
  parentId        String?  @map("parent_id") @db.Uuid
  headEmployeeId  String?  @map("head_employee_id") @db.Uuid
  costCenter      String?  @map("cost_center")
  description     String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Department? @relation("DeptHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DeptHierarchy")
  employees Employee[]
  positions Position[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("departments")
}

model Position {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  departmentId String?  @map("department_id") @db.Uuid
  title        String
  grade        String?
  band         String?
  jobFamily    String?  @map("job_family")
  isManager    Boolean  @default(false) @map("is_manager")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@index([tenantId])
  @@map("positions")
}

model Employee {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  userId            String?  @unique @map("user_id") @db.Uuid
  empCode           String   @map("emp_code")

  // Personal
  fullName          String   @map("full_name")
  email             String
  phone             String?
  dob               DateTime? @db.Date
  gender            String?
  nationalId        String?  @map("national_id")
  address           String?
  emergencyContact  String?  @map("emergency_contact")
  emergencyPhone    String?  @map("emergency_phone")

  // Employment
  departmentId      String?  @map("department_id") @db.Uuid
  positionId        String?  @map("position_id") @db.Uuid
  managerId         String?  @map("manager_id") @db.Uuid
  employmentType    EmploymentType   @default(full_time) @map("employment_type")
  status            EmploymentStatus @default(active)
  hireDate          DateTime  @map("hire_date") @db.Date
  confirmationDate  DateTime? @map("confirmation_date") @db.Date
  terminationDate   DateTime? @map("termination_date") @db.Date
  terminationReason String?   @map("termination_reason")

  // Onboarding approval gate. Existing rows default to `approved`; newly
  // created employees are forced to `pending` (and status `suspended`) by
  // the create flow until an owner/admin approves them in /admin.
  approvalStatus          ApprovalStatus @default(approved) @map("approval_status")
  approvalDecidedBy       String?        @map("approval_decided_by") @db.Uuid
  approvalDecidedAt       DateTime?      @map("approval_decided_at")
  approvalRejectionReason String?        @map("approval_rejection_reason")

  // Compensation
  baseSalary        Decimal? @map("base_salary") @db.Decimal(12, 2)
  currency          String   @default("BDT")

  // Meta
  photoUrl          String?  @map("photo_url")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?       @relation("UserEmployee", fields: [userId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  position   Position?   @relation(fields: [positionId], references: [id])
  manager    Employee?   @relation("ReportingChain", fields: [managerId], references: [id])
  reports    Employee[]  @relation("ReportingChain")

  attendance     AttendanceRecord[]
  breakSessions  BreakSession[]
  breakPenalties BreakPenalty[]
  leaveRequests  LeaveRequest[]
  leaveBalances  LeaveBalance[]
  salaries       EmployeeSalary[]
  advances       EmployeeAdvance[]
  goals          Goal[]
  reviewsAuthored Review[]   @relation("ReviewAuthor")
  reviewsReceived Review[]   @relation("ReviewSubject")
  enrollments    Enrollment[]
  documents      EmployeeDocument[]

  @@unique([tenantId, empCode])
  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, approvalStatus])
  @@index([tenantId, departmentId])
  @@map("employees")
}

model LeaveType {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  name              String
  code              String
  description       String?
  annualEntitlement Int      @default(0) @map("annual_entitlement")
  isPaid            Boolean  @default(true) @map("is_paid")
  requiresApproval  Boolean  @default(true) @map("requires_approval")
  color             String   @default("#6366f1")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requests LeaveRequest[]
  balances LeaveBalance[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("leave_types")
}

model LeaveBalance {
  id          String   @id @default(uuid()) @db.Uuid
  employeeId  String   @map("employee_id") @db.Uuid
  leaveTypeId String   @map("leave_type_id") @db.Uuid
  year        Int
  entitled    Int
  used        Int      @default(0)
  pending     Int      @default(0)
  carriedOver Int      @default(0) @map("carried_over")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @map("tenant_id") @db.Uuid
  employeeId      String      @map("employee_id") @db.Uuid
  leaveTypeId     String      @map("leave_type_id") @db.Uuid
  startDate       DateTime    @map("start_date") @db.Date
  endDate         DateTime    @map("end_date") @db.Date
  days            Int
  reason          String?
  status          LeaveStatus @default(pending)
  approvedBy      String?     @map("approved_by") @db.Uuid
  approvedAt      DateTime?   @map("approved_at")
  rejectionReason String?     @map("rejection_reason")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([tenantId, status])
  @@index([employeeId])
  @@map("leave_requests")
}

model AttendanceRecord {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  employeeId String    @map("employee_id") @db.Uuid
  date       DateTime  @db.Date
  checkIn    DateTime? @map("check_in")
  checkOut   DateTime? @map("check_out")
  workHours  Decimal?  @map("work_hours") @db.Decimal(5, 2)
  status     String    @default("present") // present | absent | late | half_day | leave | holiday
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([tenantId, date])
  @@map("attendance_records")
}

// ─── BREAK TIME ──────────────────────────────────────────────

enum BreakPenaltyStatus {
  pending
  applied
  waived
}

enum BreakStatus {
  active
  completed
}

model BreakSession {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  employeeId  String      @map("employee_id") @db.Uuid
  breakStart  DateTime    @map("break_start")
  breakEnd    DateTime?   @map("break_end")
  durationMin Int         @default(0) @map("duration_min")
  status      BreakStatus @default(active)
  notes       String?
  // "courier" = work errand → counts as working/duty time.
  // Anything else (default "personal") = out-of-duty break.
  breakCategory String    @default("personal") @map("break_category")
  isDuty        Boolean   @default(false) @map("is_duty")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  breakPenalties BreakPenalty[]

  @@index([tenantId, employeeId])
  @@index([tenantId, breakStart])
  @@map("break_sessions")
}

model BreakPenalty {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @map("tenant_id") @db.Uuid
  employeeId       String             @map("employee_id") @db.Uuid
  breakSessionId   String?            @map("break_session_id") @db.Uuid
  amount           Decimal            @db.Decimal(12, 2)
  reason           String
  status           BreakPenaltyStatus @default(pending)
  appliedAt        DateTime?          @map("applied_at")
  appliedBy        String?            @map("applied_by") @db.Uuid
  payslipId        String?            @map("payslip_id") @db.Uuid
  exceededMinutes  Int                @default(0) @map("exceeded_minutes")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee     Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  breakSession BreakSession? @relation(fields: [breakSessionId], references: [id])
  payslip      Payslip?      @relation(fields: [payslipId], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@index([payslipId])
  @@map("break_penalties")
}


// ═══════════════════════════════════════════════════════════════
// HR PHASE 2 — Payroll, Performance, Recruitment, LMS, Documents
// ═══════════════════════════════════════════════════════════════

// ─── PAYROLL ───────────────────────────────────────────────

enum PayrollPeriodStatus {
  draft
  processing
  locked
  paid
}

enum PayrollRunStatus {
  pending
  processing
  completed
  failed
}

enum SalaryComponentType {
  earning
  deduction
  reimbursement // paid on top of net pay, excluded from gross (e.g. D.H. Expenses)
}

enum PayrollColumnGroup {
  earning
  deduction
}

enum PayrollColumnOp {
  multiply
  add
  subtract
  divide
}

enum PayrollColumnOperand {
  field
  constant
}

enum AdvanceStatus {
  pending
  active
  cleared
  cancelled
}

enum SalaryComponentCalc {
  fixed
  percent_of_basic
  percent_of_gross
}

model SalaryStructure {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  components  SalaryComponent[]
  assignments EmployeeSalary[]

  @@unique([tenantId, name])
  @@map("salary_structures")
}

model SalaryComponent {
  id              String              @id @default(uuid()) @db.Uuid
  structureId     String              @map("structure_id") @db.Uuid
  name            String
  code            String
  type            SalaryComponentType
  calculationType SalaryComponentCalc @default(fixed) @map("calculation_type")
  value           Decimal             @db.Decimal(12, 2)
  taxable         Boolean             @default(false)
  isStatutory     Boolean             @default(false) @map("is_statutory")
  sortOrder       Int                 @default(0) @map("sort_order")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  structure SalaryStructure @relation(fields: [structureId], references: [id], onDelete: Cascade)

  @@map("salary_components")
}

model EmployeeSalary {
  id            String    @id @default(uuid()) @db.Uuid
  employeeId    String    @map("employee_id") @db.Uuid
  structureId   String    @map("structure_id") @db.Uuid
  baseSalary    Decimal   @map("base_salary") @db.Decimal(12, 2)
  // Per-employee allowance breakdown (these + basic form the gross salary)
  houseRent     Decimal   @default(0) @map("house_rent") @db.Decimal(12, 2)
  health        Decimal   @default(0) @db.Decimal(12, 2)
  education     Decimal   @default(0) @db.Decimal(12, 2)
  savings       Decimal   @default(0) @db.Decimal(12, 2)
  dailyHand     Decimal   @default(0) @map("daily_hand") @db.Decimal(12, 2)
  currency      String    @default("BDT")
  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")

  employee  Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  structure SalaryStructure @relation(fields: [structureId], references: [id])

  @@index([employeeId])
  @@map("employee_salaries")
}

model PayrollPeriod {
  id          String              @id @default(uuid()) @db.Uuid
  tenantId    String              @map("tenant_id") @db.Uuid
  name        String
  periodStart DateTime            @map("period_start") @db.Date
  periodEnd   DateTime            @map("period_end") @db.Date
  payDate     DateTime            @map("pay_date") @db.Date
  status      PayrollPeriodStatus @default(draft)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runs   PayrollRun[]

  @@unique([tenantId, periodStart])
  @@map("payroll_periods")
}

model PayrollRun {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  periodId        String           @map("period_id") @db.Uuid
  status          PayrollRunStatus @default(pending)
  totalGross      Decimal          @default(0) @map("total_gross") @db.Decimal(14, 2)
  totalDeductions Decimal          @default(0) @map("total_deductions") @db.Decimal(14, 2)
  totalNet        Decimal          @default(0) @map("total_net") @db.Decimal(14, 2)
  employeeCount   Int              @default(0) @map("employee_count")
  notes           String?
  runBy           String?          @map("run_by") @db.Uuid
  runAt           DateTime         @default(now()) @map("run_at")
  completedAt     DateTime?        @map("completed_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  period   PayrollPeriod @relation(fields: [periodId], references: [id])
  payslips Payslip[]

  @@index([tenantId])
  @@map("payroll_runs")
}

model Payslip {
  id              String   @id @default(uuid()) @db.Uuid
  runId           String   @map("run_id") @db.Uuid
  employeeId      String   @map("employee_id") @db.Uuid
  basicSalary     Decimal  @map("basic_salary") @db.Decimal(12, 2)
  totalEarnings   Decimal  @map("total_earnings") @db.Decimal(12, 2)
  totalDeductions Decimal  @map("total_deductions") @db.Decimal(12, 2)
  netPay          Decimal  @map("net_pay") @db.Decimal(12, 2)
  // Salary-sheet breakdown (HRM SaaS terms of payment)
  houseRent        Decimal @default(0) @map("house_rent") @db.Decimal(12, 2)
  health           Decimal @default(0) @db.Decimal(12, 2)
  education        Decimal @default(0) @db.Decimal(12, 2)
  savings          Decimal @default(0) @db.Decimal(12, 2)
  dailyHand        Decimal @default(0) @map("daily_hand") @db.Decimal(12, 2)
  extraDutyDays    Decimal @default(0) @map("extra_duty_days") @db.Decimal(5, 2)
  extraDutyPayment Decimal @default(0) @map("extra_duty_payment") @db.Decimal(12, 2)
  totalSalary      Decimal @default(0) @map("total_salary") @db.Decimal(12, 2)
  absentDays       Decimal @default(0) @map("absent_days") @db.Decimal(5, 2)
  absenceDeduction Decimal @default(0) @map("absence_deduction") @db.Decimal(12, 2)
  absenceReason    String? @map("absence_reason")
  advanceRecovered Decimal  @default(0) @map("advance_recovered") @db.Decimal(12, 2)
  breakPenalty     Decimal  @default(0) @map("break_penalty") @db.Decimal(12, 2)
  reimbursements   Decimal  @default(0) @db.Decimal(12, 2)
  payableSalary    Decimal @default(0) @map("payable_salary") @db.Decimal(12, 2)
  amountPaid       Decimal @default(0) @map("amount_paid") @db.Decimal(12, 2)
  currency        String   @default("BDT")
  generatedAt     DateTime @default(now()) @map("generated_at")
  // Per-employee salary-paid confirmation (reversible). paidBy = user id.
  paidAt          DateTime? @map("paid_at")
  paidBy          String?   @map("paid_by") @db.Uuid

  run          PayrollRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  lines        PayslipLine[]
  recoveries   AdvanceRecovery[]
  customValues PayslipCustomValue[]
  breakPenalties BreakPenalty[]

  @@unique([runId, employeeId])
  @@index([employeeId])
  @@map("payslips")
}

// Admin-defined derived columns shown on the salary sheet. Computed from a
// base payslip field via an operation against another field or a constant.
// `affectsTotal` is reserved (default false = display-only) so wiring these
// into Net Payable can be enabled later without another migration.
model PayrollCustomColumn {
  id           String               @id @default(uuid()) @db.Uuid
  tenantId     String               @map("tenant_id") @db.Uuid
  name         String
  shortLabel   String               @map("short_label")
  group        PayrollColumnGroup
  operation    PayrollColumnOp
  sourceField  String               @map("source_field")
  operandKind  PayrollColumnOperand @default(field) @map("operand_kind")
  operandField String?              @map("operand_field")
  operandValue Decimal?             @map("operand_value") @db.Decimal(14, 4)
  // Multi-term formula: [{ a:{kind,field?,value?}, op, b:{...} }, ...].
  // Column value = sum of each row's (a op b). Authoritative when set;
  // legacy operation/sourceField columns kept for backward compat.
  formula      Json?
  // Manual = admin types a value per employee on the salary sheet (no
  // formula). Computed = derived from `formula`. Display-only either way.
  manual       Boolean              @default(false)
  affectsTotal Boolean              @default(false) @map("affects_total")
  sortOrder    Int                  @default(0) @map("sort_order")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payslipValues PayslipCustomValue[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("payroll_custom_columns")
}

// Per-employee value for a MANUAL custom column (one per payslip+column).
// Display-only — summed into the sheet's Total/Net like computed custom
// columns; the stored payslip totals are never touched.
model PayslipCustomValue {
  id        String   @id @default(uuid()) @db.Uuid
  payslipId String   @map("payslip_id") @db.Uuid
  columnId  String   @map("column_id") @db.Uuid
  value     Decimal  @default(0) @db.Decimal(14, 4)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payslip Payslip             @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  column  PayrollCustomColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([payslipId, columnId])
  @@index([columnId])
  @@map("payslip_custom_values")
}

// Per-tenant overrides for BUILT-IN salary-sheet leaf columns (Basic, House
// Rent, allowances, Extra-Duty Days, Absent Days, Advance Recovery). Editing
// one triggers a persisted recompute of every run for the tenant. The raw
// pre-recompute payroll is snapshotted to PayrollRecomputeBackup first.
model PayrollBaseColumnOverride {
  id                 String              @id @default(uuid()) @db.Uuid
  tenantId           String              @map("tenant_id") @db.Uuid
  fieldKey           String              @map("field_key")
  nameOverride       String?             @map("name_override")
  shortLabelOverride String?             @map("short_label_override")
  hidden             Boolean             @default(false)
  groupOverride      PayrollColumnGroup? @map("group_override")
  // Step-chain formula over other leaf fields/constants (same shape as
  // PayrollCustomColumn.formula). Null = use the raw stored value.
  formula            Json?
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, fieldKey])
  @@index([tenantId])
  @@map("payroll_base_column_overrides")
}

// Restore point captured immediately before a tenant-wide persisted
// recompute. `snapshot` holds the raw runs/payslips/lines JSON so a recompute
// (including over completed/paid runs) can be fully reversed.
model PayrollRecomputeBackup {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  reason     String
  createdBy  String?   @map("created_by") @db.Uuid
  runCount   Int       @default(0) @map("run_count")
  slipCount  Int       @default(0) @map("slip_count")
  snapshot   Json
  restoredAt DateTime? @map("restored_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("payroll_recompute_backups")
}

model EmployeeAdvance {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  employeeId  String        @map("employee_id") @db.Uuid
  amount      Decimal       @db.Decimal(12, 2)
  installment Decimal       @db.Decimal(12, 2)
  outstanding Decimal       @db.Decimal(12, 2)
  reason      String?
  status      AdvanceStatus @default(active)
  issuedAt    DateTime      @map("issued_at") @db.Date
  // Optional recovery window. When both are set, the advance is recovered
  // only on payroll runs whose pay period falls within [start, end];
  // otherwise the default "from the month after issue" rule applies.
  recoveryStart DateTime?   @map("recovery_start") @db.Date
  recoveryEnd   DateTime?   @map("recovery_end") @db.Date
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee   Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  recoveries AdvanceRecovery[]

  @@index([tenantId, status])
  @@index([employeeId])
  @@map("employee_advances")
}

model AdvanceRecovery {
  id          String   @id @default(uuid()) @db.Uuid
  advanceId   String   @map("advance_id") @db.Uuid
  payslipId   String?  @map("payslip_id") @db.Uuid
  amount      Decimal  @db.Decimal(12, 2)
  recoveredAt DateTime @default(now()) @map("recovered_at")

  advance EmployeeAdvance @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  payslip Payslip?        @relation(fields: [payslipId], references: [id], onDelete: SetNull)

  @@index([advanceId])
  @@index([payslipId])
  @@map("advance_recoveries")
}

model PayslipLine {
  id            String              @id @default(uuid()) @db.Uuid
  payslipId     String              @map("payslip_id") @db.Uuid
  componentName String              @map("component_name")
  componentCode String              @map("component_code")
  amount        Decimal             @db.Decimal(12, 2)
  type          SalaryComponentType
  sortOrder     Int                 @default(0) @map("sort_order")

  payslip Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  @@map("payslip_lines")
}

// ─── PERFORMANCE ───────────────────────────────────────────

enum ReviewCycleStatus {
  draft
  active
  closed
}

enum GoalType {
  okr
  kpi
}

enum GoalStatus {
  not_started
  in_progress
  achieved
  missed
  cancelled
}

enum ReviewType {
  self
  manager
  peer
  upward
}

enum ReviewStatus {
  draft
  submitted
  approved
}

model ReviewCycle {
  id        String            @id @default(uuid()) @db.Uuid
  tenantId  String            @map("tenant_id") @db.Uuid
  name      String
  type      String            @default("annual")
  startDate DateTime          @map("start_date") @db.Date
  endDate   DateTime          @map("end_date") @db.Date
  status    ReviewCycleStatus @default(draft)
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  goals   Goal[]
  reviews Review[]

  @@map("review_cycles")
}

model Goal {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  employeeId   String     @map("employee_id") @db.Uuid
  cycleId      String?    @map("cycle_id") @db.Uuid
  title        String
  description  String?
  type         GoalType   @default(okr)
  targetValue  Decimal?   @map("target_value") @db.Decimal(12, 2)
  currentValue Decimal    @default(0) @map("current_value") @db.Decimal(12, 2)
  unit         String?
  weight       Int        @default(100)
  progress     Int        @default(0)
  status       GoalStatus @default(not_started)
  startDate    DateTime?  @map("start_date") @db.Date
  endDate      DateTime?  @map("end_date") @db.Date
  parentGoalId String?    @map("parent_goal_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cycle    ReviewCycle? @relation(fields: [cycleId], references: [id])
  parent   Goal?        @relation("GoalHierarchy", fields: [parentGoalId], references: [id])
  children Goal[]       @relation("GoalHierarchy")

  @@index([tenantId, employeeId])
  @@map("goals")
}

model Review {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  cycleId       String       @map("cycle_id") @db.Uuid
  employeeId    String       @map("employee_id") @db.Uuid
  reviewerId    String       @map("reviewer_id") @db.Uuid
  type          ReviewType
  overallRating Int?
  strengths     String?
  improvements  String?
  comments      String?
  status        ReviewStatus @default(draft)
  submittedAt   DateTime?    @map("submitted_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycle    ReviewCycle @relation(fields: [cycleId], references: [id])
  employee Employee    @relation("ReviewSubject", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer Employee    @relation("ReviewAuthor", fields: [reviewerId], references: [id])

  @@index([tenantId, cycleId])
  @@index([employeeId])
  @@map("reviews")
}

// ─── RECRUITMENT (ATS) ─────────────────────────────────────

enum JobPostingStatus {
  draft
  open
  on_hold
  closed
}

enum ApplicationStage {
  applied
  screening
  interview
  offer
  hired
  rejected
}

// ApprovalType is intentionally a free-form string (not an enum) so new
// approval kinds can be added in code with NO schema migration.

enum ApprovalStatus {
  pending
  approved
  rejected
}

model JobPosting {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  title           String
  departmentId    String?          @map("department_id") @db.Uuid
  positionId      String?          @map("position_id") @db.Uuid
  description     String
  requirements    String?
  employmentType  EmploymentType   @default(full_time) @map("employment_type")
  salaryMin       Decimal?         @map("salary_min") @db.Decimal(12, 2)
  salaryMax       Decimal?         @map("salary_max") @db.Decimal(12, 2)
  currency        String           @default("BDT")
  location        String?
  status          JobPostingStatus @default(draft)
  hiringManagerId String?          @map("hiring_manager_id") @db.Uuid
  openedAt        DateTime?        @map("opened_at")
  closedAt        DateTime?        @map("closed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([tenantId, status])
  @@map("job_postings")
}

model Candidate {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  fullName       String   @map("full_name")
  email          String
  phone          String?
  currentRole    String?  @map("current_role")
  currentCompany String?  @map("current_company")
  resumeUrl      String?  @map("resume_url")
  linkedinUrl    String?  @map("linkedin_url")
  source         String?
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  applications Application[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("candidates")
}

model Application {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  candidateId     String           @map("candidate_id") @db.Uuid
  jobPostingId    String           @map("job_posting_id") @db.Uuid
  stage           ApplicationStage @default(applied)
  notes           String?
  appliedAt       DateTime         @default(now()) @map("applied_at")
  rejectedAt      DateTime?        @map("rejected_at")
  rejectionReason String?          @map("rejection_reason")
  hiredAt         DateTime?        @map("hired_at")
  offerSalary     Decimal?         @map("offer_salary") @db.Decimal(12, 2)
  // Joining approval gate. Moving an application to `hired` does NOT take
  // effect until an owner/admin approves the joining in /admin. Null means
  // no joining decision is pending (normal pipeline stages).
  joiningStatus     ApprovalStatus? @map("joining_status")
  joiningDecidedBy  String?         @map("joining_decided_by") @db.Uuid
  joiningDecidedAt  DateTime?       @map("joining_decided_at")
  joiningRejectionReason String?    @map("joining_rejection_reason")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate  Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobPostingId])
  @@index([tenantId, stage])
  @@map("applications")
}

// ─── Admin: approvals inbox ─────────────────────────────────
// One row per thing awaiting an owner/admin decision. Display fields
// (title/subtitle) are denormalised so the inbox stays cheap and stable
// even if the underlying entity changes.
model ApprovalRequest {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  type        String
  status      ApprovalStatus @default(pending)
  entityType  String         @map("entity_type")
  entityId    String?        @map("entity_id") @db.Uuid
  title       String
  subtitle    String?
  payload     Json?
  requestedBy String?        @map("requested_by") @db.Uuid
  requestedByName String?    @map("requested_by_name")
  decidedBy   String?        @map("decided_by") @db.Uuid
  decidedByName String?      @map("decided_by_name")
  decidedAt   DateTime?      @map("decided_at")
  reason      String?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("approval_requests")
}

// ─── Admin: notification center ─────────────────────────────
// Persisted, tenant-scoped notifications for every notable execution and
// approval event. Read/unread is tracked per user via NotificationRead.
model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  category   String   @default("activity")
  type       String
  title      String
  body       String?
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  link       String?
  actorId    String?  @map("actor_id") @db.Uuid
  actorName  String?  @map("actor_name")
  severity   String   @default("info")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reads  NotificationRead[]

  @@index([tenantId, createdAt])
  @@index([tenantId, category])
  @@map("notifications")
}

model NotificationRead {
  id             String   @id @default(uuid()) @db.Uuid
  notificationId String   @map("notification_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  readAt         DateTime @default(now()) @map("read_at")

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId])
  @@map("notification_reads")
}

// ─── LEARNING (LMS) ────────────────────────────────────────

enum CourseLevel {
  beginner
  intermediate
  advanced
}

enum EnrollmentStatus {
  enrolled
  in_progress
  completed
  dropped
}

model Course {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @map("tenant_id") @db.Uuid
  title          String
  description    String?
  category       String?
  durationHours  Int?        @map("duration_hours")
  level          CourseLevel @default(beginner)
  instructorName String?     @map("instructor_name")
  thumbnailUrl   String?     @map("thumbnail_url")
  isPublished    Boolean     @default(false) @map("is_published")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modules     CourseModule[]
  enrollments Enrollment[]

  @@index([tenantId])
  @@map("courses")
}

model CourseModule {
  id              String   @id @default(uuid()) @db.Uuid
  courseId        String   @map("course_id") @db.Uuid
  title           String
  description     String?
  contentUrl      String?  @map("content_url")
  durationMinutes Int?     @map("duration_minutes")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_modules")
}

model Enrollment {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  courseId    String           @map("course_id") @db.Uuid
  employeeId  String           @map("employee_id") @db.Uuid
  enrolledAt  DateTime         @default(now()) @map("enrolled_at")
  startedAt   DateTime?        @map("started_at")
  completedAt DateTime?        @map("completed_at")
  progress    Int              @default(0)
  status      EnrollmentStatus @default(enrolled)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  employee      Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  certification Certification?

  @@unique([courseId, employeeId])
  @@index([tenantId, employeeId])
  @@map("enrollments")
}

model Certification {
  id                String    @id @default(uuid()) @db.Uuid
  enrollmentId      String    @unique @map("enrollment_id") @db.Uuid
  certificateNumber String    @unique @map("certificate_number")
  issuedAt          DateTime  @default(now()) @map("issued_at")
  expiresAt         DateTime? @map("expires_at")
  score             Int?

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@map("certifications")
}

// ─── DOCUMENTS (DMS + e-Sign) ──────────────────────────────

model DocumentCategory {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String
  description   String?
  retentionDays Int?     @map("retention_days")
  isRequired    Boolean  @default(false) @map("is_required")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents EmployeeDocument[]

  @@unique([tenantId, name])
  @@map("document_categories")
}

model EmployeeDocument {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  employeeId   String    @map("employee_id") @db.Uuid
  categoryId   String?   @map("category_id") @db.Uuid
  name         String
  description  String?
  fileUrl      String?   @map("file_url")
  fileSize     Int?      @map("file_size")
  mimeType     String?   @map("mime_type")
  expiresAt    DateTime? @map("expires_at")
  isSigned     Boolean   @default(false) @map("is_signed")
  signedAt     DateTime? @map("signed_at")
  signedByName String?   @map("signed_by_name")
  uploadedBy   String?   @map("uploaded_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  category DocumentCategory? @relation(fields: [categoryId], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, expiresAt])
  @@map("employee_documents")
}
