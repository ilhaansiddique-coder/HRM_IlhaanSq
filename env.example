# Production (Self-hosted Supabase)
# VITE_SUPABASE_URL=https://your-domain.com
# VITE_SUPABASE_ANON_KEY=your_production_anon_key

# Production Supabase (Replace with your own)
# VITE_SUPABASE_URL=https://your-supabase-url.com
# VITE_SUPABASE_ANON_KEY=your_production_anon_key_here

# Billing / Stripe (set as Supabase secrets for Edge Functions)
# APP_URL=https://your-app-domain.com
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# ALLOWED_ORIGINS=https://your-app-domain.com

